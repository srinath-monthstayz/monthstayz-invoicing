# Airtable personal access token.
# Create at https://airtable.com/create/tokens with scopes:
#   data.records:read, data.records:write, schema.bases:read, webhook:manage
AIRTABLE_TOKEN=pat_xxxxxxxxxxxx

# The "Main" base
AIRTABLE_BASE_ID=appND9kP55cvkDX7V

# Public URL of this app (used for the Airtable webhook + invoice links)
APP_URL=https://invoices.monthstayzthailand.com

# Any random string; Airtable webhook notifications are verified against it
WEBHOOK_SECRET=change-me

# Printed by `npm run register-webhook` after it creates the webhooks — a
# JSON object of { webhookId: macSecretBase64 }, used to verify Airtable's
# X-Airtable-Content-MAC header. Optional but recommended.
AIRTABLE_WEBHOOK_SECRETS_JSON=

# Shared team password for the whole dashboard. Leave blank to disable the
# login gate entirely (not recommended once CRM/passport data is visible).
APP_PASSWORD=change-me

# Shown on invoices / receipts
COMPANY_NAME=MonthStayz Thailand
COMPANY_TAGLINE=Experience Luxury Living in Thailand
COMPANY_ADDRESS=Phuket, Thailand
COMPANY_EMAIL=srinath@monthstayzthailand.com
COMPANY_PHONE=
# Defaults to the bundled /logo.avif (public/logo.avif) if unset
COMPANY_LOGO_URL=
